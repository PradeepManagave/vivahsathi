# ============================================================================
# M-Plus Matrimony - Frontend Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# Application
NEXT_PUBLIC_APP_NAME="M-Plus Matrimony"
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_VERSION=1.0.0
NODE_ENV=development

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_API_TIMEOUT=30000
NEXT_PUBLIC_API_RETRY_COUNT=3

# Authentication
NEXT_PUBLIC_JWT_EXPIRY=7d
NEXT_PUBLIC_REFRESH_TOKEN_EXPIRY=30d
NEXT_PUBLIC_AUTH_COOKIE_NAME=mplus_auth_token
NEXT_PUBLIC_REFRESH_COOKIE_NAME=mplus_refresh_token

# Feature Flags
NEXT_PUBLIC_FEATURE_VIDEO_KYC=true
NEXT_PUBLIC_FEATURE_VIDEO_CHAT=true
NEXT_PUBLIC_FEATURE_WHATSAPP=true
NEXT_PUBLIC_FEATURE_MARKETPLACE=true
NEXT_PUBLIC_FEATURE_ADS=true
NEXT_PUBLIC_FEATURE_MULTILINGUAL=true
NEXT_PUBLIC_FEATURE_AI_MATCHES=true

# Analytics & Tracking
NEXT_PUBLIC_GOOGLE_ANALYTICS_ID=G-XXXXXXXXXX
NEXT_PUBLIC_GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX
NEXT_PUBLIC_FACEBOOK_PIXEL_ID=

# Google reCAPTCHA
NEXT_PUBLIC_GOOGLE_RECAPTCHA_SITE_KEY=6LeXXXXXXXXXXXXXXXXXXXXXXXXAAAAAA

# Firebase (Push Notifications)
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=mplus-matrimony.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=mplus-matrimony
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=mplus-matrimony.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abc123def456

# CDN & Media
NEXT_PUBLIC_CDN_URL=https://cdn.mplus.example.com
NEXT_PUBLIC_IMAGE_PROXY_URL=https://images.mplus.example.com
NEXT_PUBLIC_MAX_UPLOAD_SIZE_MB=5
NEXT_PUBLIC_MAX_PHOTOS_COUNT=10

# WhatsApp
NEXT_PUBLIC_WHATSAPP_BUSINESS_NUMBER=919876543210
NEXT_PUBLIC_WHATSAPP_SHARE_TEXT="Check out this profile on M-Plus Matrimony!"

# Social Login
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
NEXT_PUBLIC_FACEBOOK_APP_ID=your-facebook-app-id

# Localization
NEXT_PUBLIC_DEFAULT_LANGUAGE=en
NEXT_PUBLIC_SUPPORTED_LANGUAGES=en,hi,mr
NEXT_PUBLIC_FALLBACK_LANGUAGE=en

# SEO & Meta
NEXT_PUBLIC_SITE_NAME="M-Plus Matrimony"
NEXT_PUBLIC_SITE_DESCRIPTION="Find your perfect match with verified profiles. Trusted matrimony platform for Marathi, Hindi-speaking communities."
NEXT_PUBLIC_OG_IMAGE_URL=https://cdn.mplus.example.com/og-default.jpg
NEXT_PUBLIC_TWITTER_HANDLE=@mplussathi
NEXT_PUBLIC_FAVICON_URL=/favicon.ico

# PWA
NEXT_PUBLIC_SERVICE_WORKER_ENABLED=true
NEXT_PUBLIC_PWA_VERSION=1.0.0

# Video Services
NEXT_PUBLIC_VIDEO_PROVIDER=daily
NEXT_PUBLIC_DAILY_API_URL=https://api.daily.co/v1

# Payment (Stripe - Frontend Public Key)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Membership Plan Limits
NEXT_PUBLIC_FREE_CONTACTS_PER_DAY=5
NEXT_PUBLIC_FREE_MESSAGE_LIMIT=10
NEXT_PUBLIC_TRIAL_DAYS=7

# Privacy & Consent
NEXT_PUBLIC_COOKIE_CONSENT_ENABLED=true
NEXT_PUBLIC_PRIVACY_POLICY_URL=/privacy-policy
NEXT_PUBLIC_TERMS_URL=/terms-of-service

# Debug & Development
NEXT_PUBLIC_ENABLE_DEBUG_MODE=false
NEXT_PUBLIC_LOG_LEVEL=warn
NEXT_PUBLIC_MOCK_API=false

# Federation / Multi-tenancy
NEXT_PUBLIC_FRANCHISE_SUBDOMAIN=members
NEXT_PUBLIC_DEFAULT_COUNTRY=india
NEXT_PUBLIC_DEFAULT_STATE=maharashtra

# ============================================================================
# M-Plus Matrimony - Frontend Environment Variables
# ============================================================================
# Copy this to .env.local and fill in your values

# API
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# App Info
NEXT_PUBLIC_APP_NAME="M-Plus Matrimony"
NEXT_PUBLIC_APP_TAGLINE="Where Heritage Meets Forever"

# OAuth (for social login)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
NEXT_PUBLIC_FACEBOOK_APP_ID=your-facebook-app-id

# Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX
NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@sentry.io/xxxxxx
NEXT_PUBLIC_MIXPANEL_TOKEN=your-mixpanel-project-token
NEXT_PUBLIC_AMPLITUDE_API_KEY=your-amplitude-api-key

# Feature Flags
NEXT_PUBLIC_FEATURE_VIDEO_KYC=true
NEXT_PUBLIC_FEATURE_VIDEO_CHAT=true
NEXT_PUBLIC_FEATURE_MARKETPLACE=true

# Recaptcha
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=6LeXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Maps
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Environment
NEXT_PUBLIC_ENVIRONMENT=dev

# --- Dev Overrides (copy to .env.development) ---
# NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
# NEXT_PUBLIC_ENVIRONMENT=dev

# --- Staging Overrides (copy to .env.staging) ---
# NEXT_PUBLIC_API_URL=https://staging-api.vivahsathi.com/api/v1
# NEXT_PUBLIC_ENVIRONMENT=staging

# --- Production Overrides (copy to .env.production) ---
# NEXT_PUBLIC_API_URL=https://api.vivahsathi.com/api/v1
# NEXT_PUBLIC_ENVIRONMENT=prod
# NEXT_PUBLIC_SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@sentry.io/prod

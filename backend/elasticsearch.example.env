# ============================================================================
# Elasticsearch Configuration Guide
# ============================================================================
# The VivahSathi platform has full Elasticsearch integration built in.
# Copy this file to .env or to your deployment environment and fill in values.
# ============================================================================

# Set to 'true' to enable Elasticsearch-powered search
ELASTICSEARCH_ENABLED=false

# Elasticsearch node URL (single node or load-balanced cluster)
ELASTICSEARCH_NODE=http://localhost:9200

# API key for Elasticsearch authentication (optional, if using API key auth)
# Generate via: kibana > Stack Management > API Keys
ELASTICSEARCH_API_KEY=

# Username/Password auth (alternative to API key)
# ELASTICSEARCH_USERNAME=elastic
# ELASTICSEARCH_PASSWORD=changeme

# Index names (will be auto-created by the indexer)
ELASTICSEARCH_PROFILES_INDEX=vivahsathi_profiles
ELASTICSEARCH_USERS_INDEX=vivahsathi_users

# Index settings
ELASTICSEARCH_SHARDS=3
ELASTICSEARCH_REPLICAS=2

# ============================================================================
# Quick Start
# ============================================================================
# 1. Install & start Elasticsearch (v8.x+):
#    docker run -d --name elasticsearch \
#      -p 9200:9200 -p 9300:9300 \
#      -e "discovery.type=single-node" \
#      -e "xpack.security.enabled=false" \
#      docker.elastic.co/elasticsearch/elasticsearch:8.12.0
#
# 2. Set ELASTICSEARCH_ENABLED=true and ELASTICSEARCH_NODE=http://localhost:9200
#
# 3. The indexer auto-creates indices on first reindex request
#
# 4. Trigger a full reindex: POST /api/v1/search/reindex
#
# 5. All search queries automatically use ES when enabled,
#    falling back to PostgreSQL when disabled or on error
# ============================================================================

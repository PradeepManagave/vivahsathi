# ============================================================================
# M-Plus Matrimony - Backend Environment Variables
# ============================================================================

# Application
NODE_ENV=development
APP_NAME="M-Plus API"
APP_URL=http://localhost:4000
APP_PORT=4000
APP_DEBUG=true
APP_TIMEZONE=Asia/Kolkata
APP_SECRET_KEY=your-super-secret-key-change-in-production-at-least-64-chars

# Server
HOST=0.0.0.0
PORT=4000
CORS_ORIGIN=http://localhost:3000
API_PREFIX=/api/v1

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mplus_matrimony
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_SSL=false
DB_LOGGING=true

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0
REDIS_KEY_PREFIX=mplus:

# Elasticsearch
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_INDEX_PREFIX=mplus
ELASTICSEARCH_REQUEST_TIMEOUT=30000

# JWT Authentication
JWT_SECRET=your-jwt-secret-key-change-this-in-production-min-64-chars
JWT_EXPIRES_IN=7d
JWT_ALGORITHM=HS256
REFRESH_TOKEN_SECRET=your-refresh-token-secret-key-change-in-production
REFRESH_TOKEN_EXPIRES_IN=30d

# Password
PASSWORD_MIN_LENGTH=8
PASSWORD_HASH_ROUNDS=12

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MS=900000
SEARCH_RATE_LIMIT_MAX=30

# 2FA
TOTP_ISSUER=M-Plus Matrimony
TOTP_WINDOW=1

# Session
SESSION_SECRET=your-session-secret-change-in-production
SESSION_MAX_AGE=86400000

# Email - SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_NAME="M-Plus Matrimony"
SMTP_FROM_EMAIL=noreply@mplus.example.com
SMTP_REPLY_TO=support@mplus.example.com

# Alternative Email - Amazon SES
AWS_SES_ACCESS_KEY=your-ses-access-key
AWS_SES_SECRET_KEY=your-ses-secret-key
AWS_SES_REGION=ap-south-1
AWS_SES_FROM_EMAIL=noreply@mplus.example.com

# SMS - MSG91
SMS_PROVIDER=msg91
MSG91_AUTH_KEY=your-msg91-auth-key
MSG91_SENDER_ID=MPLUSM
MSG91_TEMPLATE_ID=your-template-id
MSG91_DLT_TEMPLATE_ID=your-dlt-template-id

# SMS - Twilio
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+15005555006

# WhatsApp Business API
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token
WHATSAPP_API_VERSION=v18.0

# Payment - Razorpay
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
RAZORPAY_WEBHOOK_URL=/api/v1/payments/razorpay/webhook

# Payment - PayPal
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=sandbox
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id

# Payment - Stripe
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_CURRENCY=inr

# Storage - AWS S3
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=mplus-uploads
AWS_S3_BUCKET_URL=https://mplus-uploads.s3.ap-south-1.amazonaws.com
AWS_S3_MAX_FILE_SIZE=5242880

# Alternative Storage - Cloudflare R2
R2_ACCOUNT_ID=your-r2-account-id
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_BUCKET=mplus-uploads
R2_PUBLIC_URL=https://cdn.mplus.example.com

# CDN
CDN_URL=https://cdn.mplus.example.com
CDN_API_KEY=your-cdn-api-key

# Video - Daily.co
VIDEO_PROVIDER=daily
DAILY_API_KEY=your-daily-api-key
DAILY_API_URL=https://api.daily.co/v1
DAILY_ROOM_PREFIX=mplus_
DAILY_MAX_PARTICIPANTS=2
DAILY_RECORDING_ENABLED=true

# Push Notifications - Firebase
FIREBASE_PROJECT_ID=mplus-matrimony
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@xxxxx.iam.gserviceaccount.com
FIREBASE_CLIENT_X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk%40xxxxx.iam.gserviceaccount.com

# Google Services
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/v1/auth/google/callback

# Facebook OAuth
FACEBOOK_APP_ID=your-facebook-app-id
FACEBOOK_APP_SECRET=your-facebook-app-secret
FACEBOOK_REDIRECT_URI=http://localhost:4000/api/v1/auth/facebook/callback

# Google reCAPTCHA
GOOGLE_RECAPTCHA_SECRET_KEY=6LeXXXXXXXXXXXXXXXXXXXXXXXXAAAAAA
GOOGLE_RECAPTCHA_SCORE_THRESHOLD=0.5

# Google Analytics
GA_TRACKING_ID=G-XXXXXXXXXX
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE_ENABLED=true
LOG_FILE_PATH=./logs
LOG_FILE_MAX_SIZE=100m
LOG_FILE_MAX_FILES=14
LOG_CONSOLE_ENABLED=true

# Ad Monetization
GOOGLE_ADSENSE_PUBLISHER_ID=ca-pub-xxxxxxxxxxxxxxxx
ADMOB_APP_ID=ca-app-pub-xxxxxxxx~xxxxxxxxxx

# Queue (BullMQ)
QUEUE_HOST=localhost
QUEUE_PORT=6379
QUEUE_PASSWORD=your-queue-password
QUEUE_CONCURRENCY=5

# Cron Jobs
CRON_ENABLED=true
CRON_TIMEZONE=Asia/Kolkata

# Franchise Defaults
DEFAULT_COMMISSION_RATE=10
DEFAULT_FRANCHISE_SUBDOMAIN=members

# Membership Defaults
FREE_PLAN_CONTACTS_PER_DAY=5
FREE_PLAN_MESSAGE_LIMIT=10
TRIAL_DAYS=7

# Geo Data
DEFAULT_COUNTRY_ID=india
GEO_CACHE_TTL=86400

# Cleanup & Maintenance
DATA_RETENTION_DAYS=365
LOG_RETENTION_DAYS=90
BACKUP_ENABLED=true
BACKUP_SCHEDULE="0 2 * * *"
BACKUP_PATH=./backups

# Feature Flags
FEATURE_VIDEO_KYC=true
FEATURE_VIDEO_CHAT=true
FEATURE_WHATSAPP=true
FEATURE_MARKETPLACE=true
FEATURE_ADS=true
FEATURE_MULTILINGUAL=true
FEATURE_AI_MATCHES=true

# Maintenance Mode
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE="System under maintenance. Please try again later."

# ============================================================================
# M-Plus Matrimony - Root Environment Variables
# ============================================================================
# Copy this to .env and fill in your values

# Backend
BACKEND_PORT=4000
DB_HOST=localhost
DB_PORT=5432
DB_NAME=mplus_matrimony
DB_USER=postgres
DB_PASSWORD=change_me
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me

# JWT (min 64 chars each)
JWT_SECRET=change-this-to-a-minimum-of-64-characters-in-production
REFRESH_TOKEN_SECRET=change-this-to-another-minimum-of-64-characters
APP_SECRET_KEY=change-this-to-a-secure-secret-key-at-least-64-chars

# AWS S3 (live credentials)
AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXXXXXXXXXX
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=ap-south-1
AWS_S3_BUCKET=mplus-uploads-prod

# Payment Gateways
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxx
RAZORPAY_KEY_SECRET=rzp_secret_xxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_WEBHOOK_ID=your-paypal-webhook-id
PAYPAL_MODE=sandbox
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx

# Analytics & Monitoring
MIXPANEL_TOKEN=your-mixpanel-project-token
AMPLITUDE_API_KEY=your-amplitude-api-key
SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@sentry.io/xxxxxx
SENTRY_ENVIRONMENT=production
LOG_LEVEL=info
LOG_FILE_ENABLED=true
LOG_FILE_PATH=./logs

# CDN
CDN_URL=https://dxxxxxxxxxxxx.cloudfront.net
CDN_BUCKET_ORIGIN=vivahsathi-uploads-prod

# Environment (dev / staging / prod)
NODE_ENV=development

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ============================================================================
# Environment-specific overrides
# ============================================================================
# For staging, copy relevant section to .env.staging
# For production, copy relevant section to .env.production
# ============================================================================

# --- Staging ---
# NODE_ENV=staging
# BACKEND_PORT=4000
# DB_HOST=staging-db.vivahsathi.com
# DB_PORT=5432
# DB_NAME=vivahsathi_staging
# DB_USER=staging_user
# DB_PASSWORD=change_me_staging
# REDIS_HOST=staging-redis.vivahsathi.com
# REDIS_PORT=6379
# REDIS_PASSWORD=change_me_staging
# JWT_SECRET=staging-jwt-secret-min-64-chars-long-string-here
# REFRESH_TOKEN_SECRET=staging-refresh-secret-min-64-chars-long-here
# AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXX
# AWS_SECRET_ACCESS_KEY=staging-aws-secret-key
# AWS_REGION=ap-south-1
# AWS_S3_BUCKET=vivahsathi-uploads-staging
# NEXT_PUBLIC_API_URL=https://staging-api.vivahsathi.com/api/v1
# NEXT_PUBLIC_APP_URL=https://staging.vivahsathi.com

# --- Production ---
# NODE_ENV=production
# BACKEND_PORT=4000
# DB_HOST=prod-db.vivahsathi.com
# DB_PORT=5432
# DB_NAME=vivahsathi_prod
# DB_USER=prod_user
# DB_PASSWORD=change_me_prod
# REDIS_HOST=prod-redis.vivahsathi.com
# REDIS_PORT=6379
# REDIS_PASSWORD=change_me_prod
# JWT_SECRET=prod-jwt-secret-min-64-chars-long-string-here
# REFRESH_TOKEN_SECRET=prod-refresh-secret-min-64-chars-long-here
# AWS_ACCESS_KEY_ID=AKIAXXXXXXXXXX
# AWS_SECRET_ACCESS_KEY=prod-aws-secret-key
# AWS_REGION=ap-south-1
# AWS_S3_BUCKET=vivahsathi-uploads-prod
# NEXT_PUBLIC_API_URL=https://api.vivahsathi.com/api/v1
# NEXT_PUBLIC_APP_URL=https://vivahsathi.com

# Docker Compose
COMPOSE_PROJECT_NAME=mplus
